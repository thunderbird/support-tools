{
  "name": "sumo-kb-tools",
  "version": "0.1.0",
  "description": "Tools to draft, edit, and publish SUMO Knowledge Base articles via Google Docs",
  "type": "module",
  "bin": {
    "sumo": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "fetch": "tsx src/index.ts fetch",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@google-cloud/local-auth": "^3.0.1",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "googleapis": "^144.0.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
